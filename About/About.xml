<?xml version="1.0" encoding="utf-8"?>
<ModMetaData>
  <author>MilkCum</author>
  <packageId>TianTian.MilkCum</packageId>
  <name>精液和母乳</name>

  <supportedVersions>
    <li>1.6</li>
  </supportedVersions>

  <!-- 前置依赖：缺一不可，未安装则无法启用本 mod -->
  <modDependencies>
    <li>
      <packageId>brrainz.harmony</packageId>
      <displayName>Harmony</displayName>
      <steamWorkshopUrl>steam://url/CommunityFilePage/2009463077</steamWorkshopUrl>
      <downloadUrl>https://github.com/pardeike/HarmonyRimWorld/releases/latest</downloadUrl>
    </li>
    <li>
      <packageId>Ludeon.RimWorld.Biotech</packageId>
      <displayName>Biotech（生物科技 DLC）</displayName>
    </li>
    <li>
      <packageId>rim.job.world</packageId>
      <displayName>RimJobWorld（RJW）</displayName>
      <downloadUrl>https://gitgud.io/Ed86/rjw</downloadUrl>
    </li>
    <li>
      <packageId>rjw.menstruation</packageId>
      <displayName>RJW Menstruation Cycle</displayName>
      <downloadUrl>https://gitgud.io/lutepickle/rjw_menstruation</downloadUrl>
    </li>
    <li>
      <packageId>eltoro.rjw.menstruation.fluids</packageId>
      <displayName>RJW Menstruation - Fluids</displayName>
      <downloadUrl>https://gitgud.io/ElToro/rjw-menstruation-fluids</downloadUrl>
    </li>
  </modDependencies>

  <!-- 加载顺序：本 mod 在这些 mod 之后加载（可选 mod 也会参与排序） -->
  <loadAfter>
    <li>Ludeon.RimWorld.Core</li>
    <li>brrainz.harmony</li>
    <li>Ludeon.RimWorld.Biotech</li>
    <li>rim.job.world</li>
    <li>rjw.menstruation</li>
    <li>eltoro.rjw.menstruation.fluids</li>
    <li>drilledhead.milkexpanded</li>
    <li>akaster.vme.patch</li>
    <li>oskarpotocki.vanillafactionsexpanded.core</li>
    <li>c0ffee.rimworld.animations</li>
  </loadAfter>

  <!-- 本 mod 需在这些 mod 之前加载（如 rjw-genes 依赖本 mod 的 Def） -->
  <loadBefore>
    <li>Vegapnk.rjw.genes</li>
  </loadBefore>

  <!-- 已知冲突：与以下 mod 同时启用会导致功能重复或报错，请勿同时订阅 -->
  <incompatibleWith>
    <li>rjw.milk.humanoid</li>
    <li>Mlie.MilkableColonists</li>
    <li>tory187.rjw.gatheredrjw</li>
    <li>rjw.bucket</li>
    <li>parciwal.cumpliationlite</li>
    <li>vegapnk.cumpilation</li>
    <li>bipassed.milkingmachine</li>
  </incompatibleWith>

  <description>
泌乳与精液系统。牛奶和精液合二为一的模组。
  - 牛奶：泌乳、泵送、可食用者（允许的消费者）。
  - 精液：精液膨胀、放气（桶/泵）、手术；生产者/消费者规则相同。
  - 药物：进入泌乳期使用 EM_Prolactin 或 EM_Lucilactin；泌乳期增加产奶量使用催乳剂（Cumpilation_Galactogogues）。
  - RJW 流体力学、群交、填充、生物雕塑循环、Slug（Biotech）、非精液处理器（Samenstein/Spermatuch）。
  - 硬前置：RJW Menstruation Cycle（rjw.menstruation）与 RJW Menstruation - Fluids（eltoro）。充盈由 MF 负责；桶泄/脏泄/手术等与 MF 内部精液列表联动，编译需能在 Directory.Build.props 配置路径下找到 RJW_Menstruation 与 RJW_Menstruation_Fluids 程序集。
  </description>
</ModMetaData>