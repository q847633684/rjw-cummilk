<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef Name="EM_MilkingApparelBase" ParentName="ApparelMakeableBase" Abstract="True">
    <techLevel>Industrial</techLevel>
    <costStuffCount>45</costStuffCount>
    <stuffCategories>
      <li>Leathery</li>
      <li>Fabric</li>
    </stuffCategories>
    <thingCategories>
      <li>Apparel</li>
    </thingCategories>
    <statBases>
      <MaxHitPoints>180</MaxHitPoints>
      <WorkToMake>7000</WorkToMake>
      <Mass>1</Mass>
      <EquipDelay>0.8</EquipDelay>
    </statBases>
    <tickerType>Never</tickerType>
