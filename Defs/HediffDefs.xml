<Defs>
    <!-- hediffClass 在 Init() 中设为 Hediff_ProlactinTolerance，避免 Def 加载时程序集未就绪导致 type 为 null -->
    <HediffDef>
        <defName>EM_Prolactin_Tolerance</defName>
        <hediffClass>HediffWithComps</hediffClass>
        <label>Prolactin tolerance</label>
        <description>The body adapts to prolactin: each dose does less, and when the drug fades, lactation eases faster. Tolerance wears off after long breaks. Very strong tolerance (75% or more) can strain the kidneys over years of use.</description>
        <initialSeverity>0.01</initialSeverity>
        <maxSeverity>1.0</maxSeverity>
        <isBad>false</isBad>
        <comps>
            <li Class="HediffCompProperties_SeverityPerDay">
                <severityPerDay>-0.015</severityPerDay>
            </li>
            <li Class="HediffCompProperties_DrugEffectFactor">
                <chemical>EM_Prolactin_Chemical</chemical>
            </li>
        </comps>
        <stages>
            <li>
                <minSeverity>0</minSeverity>
                <label>mild tolerance</label>
            </li>
            <li>
                <minSeverity>0.3</minSeverity>
                <label>moderate tolerance</label>
                <statFactors>
                    <DrugDurationMultiplier>0.9</DrugDurationMultiplier>
                </statFactors>
            </li>
            <li>
                <minSeverity>0.6</minSeverity>
                <label>high tolerance</label>
                <statFactors>
                    <DrugDurationMultiplier>0.7</DrugDurationMultiplier>
                </statFactors>
                <hediffGivers>
                    <li Class="HediffGiver_RandomDrugEffect">
                        <hediff>ChemicalDamageModerate</hediff>
                        <minSeverity>0.75</minSeverity>
                        <baseMtbDays>180</baseMtbDays>
                        <partsToAffect>
                            <li>Kidney</li>
                        </partsToAffect>
                    </li>
                </hediffGivers>
            </li>
        </stages>
    </HediffDef>
    
    <!-- 短期“high”状态：愉悦 + 轻微负面（操纵/移动/意识） -->
    <HediffDef>
        <defName>EM_Prolactin_High</defName>
        <hediffClass>HediffWithComps</hediffClass>
        <label>Prolactin rush</label>
        <description>A warm, floaty lift from prolactin, with slightly clumsy hands and a fuzzy head.</description>
        <defaultLabelColor>(1,0.6,0.8)</defaultLabelColor>
        <maxSeverity>1.0</maxSeverity>
        <isBad>false</isBad>
        <comps>
            <li Class="HediffCompProperties_SeverityPerDay">
                <severityPerDay>-1</severityPerDay>
            </li>
        </comps>
        <stages>
            <li>
                <painFactor>0.9</painFactor>
                <capMods>
                    <li>
                        <capacity>Consciousness</capacity>
                        <offset>-0.10</offset>
                    </li>
                    <li>
                        <capacity>Manipulation</capacity>
                        <setMax>0.5</setMax>
                    </li>
                    <li>
                        <capacity>Moving</capacity>
                        <setMax>0.5</setMax>
                    </li>
                </capMods>
            </li>
        </stages>
    </HediffDef>
    
    <!-- 不继承 AddictionBase，避免 1.6 中 HediffDef 无 chemical 字段导致 Def 报错 -->
    <HediffDef>
        <defName>EM_Prolactin_Addiction</defName>
        <hediffClass>Hediff_Addiction</hediffClass>
        <label>Prolactin dependence</label>
        <description>The body expects regular prolactin; going without brings a harsh, restless crash.</description>
        <chemicalNeed>Chemical_EM_Prolactin_Chemical</chemicalNeed>
        <initialSeverity>0.5</initialSeverity>
        <maxSeverity>1.0</maxSeverity>
        <defaultLabelColor>(1,0,0.5)</defaultLabelColor>
        <scenarioCanAdd>true</scenarioCanAdd>
        <removeOnRedressChanceByDaysCurve>
            <points>
                <li>(0, 0)</li>
                <li>(10, 0)</li>
                <li>(60, 0.25)</li>
            </points>
        </removeOnRedressChanceByDaysCurve>
        <comps>
            <li Class="HediffCompProperties_SeverityPerDay">
                <severityPerDay>-0.015</severityPerDay>
                <showDaysToRecover>true</showDaysToRecover>
            </li>
        </comps>
        <stages>
            <li>
                <label>steady</label>
            </li>
            <li>
                <label>withdrawal</label>
                <painFactor>2.0</painFactor>
                <restFallFactorOffset>0.3</restFallFactorOffset>
                <hungerRateFactorOffset>0.5</hungerRateFactorOffset>
                <capMods>
                    <li>
                        <capacity>Consciousness</capacity>
                        <offset>-0.15</offset>
                    </li>
                    <li>
                        <capacity>Eating</capacity>
                        <offset>-0.20</offset>
                    </li>
                </capMods>
            </li>
        </stages>
    </HediffDef>
    
    <!-- Lactation breast conditions; logic in MilkRelatedHealthHelper -->
    <HediffDef>
        <defName>EM_BreastsEngorged</defName>
        <hediffClass>HediffWithComps</hediffClass>
        <label>Engorged breasts</label>
        <description>The breasts are heavy and tight with milk, making it awkward to move or work. This is mostly “too full” discomfort (physiologic engorgement): emptying on time usually brings relief. It is not the same as a blocked-duct picture—see “Backed-up milk” if emptying stops helping.</description>
        <defaultLabelColor>(0.95,0.85,0.6)</defaultLabelColor>
        <isBad>true</isBad>
        <stages>
            <li>
                <minSeverity>0</minSeverity>
                <label>Tight and sore</label>
                <capMods>
                    <li>
                        <capacity>Moving</capacity>
                        <offset>-0.05</offset>
                    </li>
                    <li>
                        <capacity>Manipulation</capacity>
                        <offset>-0.03</offset>
                    </li>
                </capMods>
            </li>
        </stages>
    </HediffDef>
    <HediffDef>
        <defName>EM_LactationalMilkStasis</defName>
        <hediffClass>HediffWithComps</hediffClass>
        <label>Backed-up milk</label>
        <description>Milk is building inside with nowhere to go; the breast feels dense and tender, and even a light touch hurts. In this mod it models poor drainage / stasis risk: if milk keeps getting left behind, inflammation risk rises. Frequent, thorough emptying is the main way to ease it.</description>
        <defaultLabelColor>(0.92,0.7,0.45)</defaultLabelColor>
        <initialSeverity>0.15</initialSeverity>
        <maxSeverity>1.0</maxSeverity>
        <isBad>true</isBad>
        <comps>
            <li Class="HediffCompProperties_SeverityPerDay">
                <severityPerDay>-0.03</severityPerDay>
            </li>
            <li Class="MilkCum.Fluids.Lactation.Hediffs.HediffCompProperties_MastitisDrainageRelief" />
        </comps>
        <stages>
            <li>
                <minSeverity>0</minSeverity>
                <label>Dull ache</label>
                <capMods>
                    <li>
                        <capacity>Moving</capacity>
                        <offset>-0.02</offset>
                    </li>
                </capMods>
            </li>
            <li>
                <minSeverity>0.5</minSeverity>
                <label>Deep ache, lumpy</label>
                <capMods>
                    <li>
                        <capacity>Moving</capacity>
                        <offset>-0.04</offset>
                    </li>
                    <li>
                        <capacity>Manipulation</capacity>
                        <offset>-0.02</offset>
                    </li>
                </capMods>
            </li>
        </stages>
    </HediffDef>
    <HediffDef>
        <defName>EM_Mastitis</defName>
        <hediffClass>HediffWithComps</hediffClass>
        <label>Mastitis</label>
        <description>The breast is hot, red, and painfully swollen; you feel drained and feverish, as if burning up. The mod uses a simplified risk model (not a full infection simulator): lingering backed-up milk, poor cleanliness, or chest injuries all push risk. Rest, keep emptying the breast, and keep wounds clean—or it may fester into something worse.</description>
        <defaultLabelColor>(0.9,0.55,0.35)</defaultLabelColor>
        <initialSeverity>0.2</initialSeverity>
        <maxSeverity>1.0</maxSeverity>
        <isBad>true</isBad>
        <comps>
            <li Class="HediffCompProperties_SeverityPerDay">
                <severityPerDay>-0.02</severityPerDay>
            </li>
            <li Class="MilkCum.Fluids.Lactation.Hediffs.HediffCompProperties_MastitisDrainageRelief" />
        </comps>
        <stages>
            <li>
                <minSeverity>0</minSeverity>
                <label>Early swelling</label>
                <capMods>
                    <li>
                        <capacity>Consciousness</capacity>
                        <offset>-0.01</offset>
                    </li>
                </capMods>
            </li>
            <li>
                <minSeverity>0.4</minSeverity>
                <label>Spreading redness</label>
                <capMods>
                    <li>
                        <capacity>Consciousness</capacity>
                        <offset>-0.03</offset>
                    </li>
                    <li>
                        <capacity>Manipulation</capacity>
                        <offset>-0.03</offset>
                    </li>
                </capMods>
            </li>
            <li>
                <minSeverity>0.72</minSeverity>
                <label>High fever, worsening</label>
                <capMods>
                    <li>
                        <capacity>Consciousness</capacity>
                        <offset>-0.06</offset>
                    </li>
                    <li>
                        <capacity>Manipulation</capacity>
                        <offset>-0.05</offset>
                    </li>
                </capMods>
            </li>
        </stages>
    </HediffDef>
    <HediffDef>
        <defName>EM_BreastAbscess</defName>
        <hediffClass>HediffWithComps</hediffClass>
        <label>Breast abscess</label>
        <description>It feels like pus has gathered in the breast; the pain is severe and chills and fever wrack the body. Often follows inflammation that was not curbed while living filthy and exhausted. Milking alone may not be enough—good care helps; skilled surgery to drain it speeds recovery.</description>
        <defaultLabelColor>(0.85,0.35,0.3)</defaultLabelColor>
        <initialSeverity>0.38</initialSeverity>
        <maxSeverity>1.0</maxSeverity>
        <isBad>true</isBad>
        <comps>
            <li Class="HediffCompProperties_SeverityPerDay">
                <severityPerDay>-0.008</severityPerDay>
            </li>
            <li Class="MilkCum.Fluids.Lactation.Hediffs.HediffCompProperties_MastitisDrainageRelief" />
        </comps>
        <stages>
            <li>
                <minSeverity>0</minSeverity>
                <label>Localized pus</label>
                <capMods>
                    <li>
                        <capacity>Consciousness</capacity>
                        <offset>-0.08</offset>
                    </li>
                    <li>
                        <capacity>Moving</capacity>
                        <offset>-0.08</offset>
                    </li>
                    <li>
                        <capacity>Manipulation</capacity>
                        <offset>-0.06</offset>
                    </li>
                </capMods>
            </li>
            <li>
                <minSeverity>0.55</minSeverity>
                <label>Spreading abscess</label>
                <capMods>
                    <li>
                        <capacity>Consciousness</capacity>
                        <offset>-0.12</offset>
                    </li>
                    <li>
                        <capacity>Moving</capacity>
                        <offset>-0.12</offset>
                    </li>
                    <li>
                        <capacity>Manipulation</capacity>
                        <offset>-0.10</offset>
                    </li>
                </capMods>
            </li>
        </stages>
    </HediffDef>
    <!-- Drug-driven lactation strain; stacks with EM_LactatingGain -->
    <HediffDef>
        <defName>EM_DrugLactationBurden</defName>
        <hediffClass>HediffWithComps</hediffClass>
        <label>Prolactin drag</label>
        <description>The dose keeps the breasts producing, but the body lags: limbs feel leaden and focus comes hard.</description>
        <defaultLabelColor>(0.85,0.75,0.9)</defaultLabelColor>
        <isBad>true</isBad>
        <stages>
            <li>
                <minSeverity>0</minSeverity>
                <label>Heavy and tired</label>
                <capMods>
                    <li>
                        <capacity>Moving</capacity>
                        <offset>-0.02</offset>
                    </li>
                    <li>
                        <capacity>Manipulation</capacity>
                        <offset>-0.01</offset>
                    </li>
                </capMods>
            </li>
        </stages>
    </HediffDef>
    <!-- Positive lactation buff; capMods from CompEquallyMilkable -->
    <HediffDef>
        <defName>EM_LactatingGain</defName>
        <hediffClass>MilkCum.Fluids.Lactation.Hediffs.Hediff_LactatingGain</hediffClass>
        <label>Milking vigor</label>
        <description>With milk flowing smoothly, you feel oddly sharp—lighter on your feet, steadier in the hands.</description>
        <defaultLabelColor>(0.6,0.9,0.7)</defaultLabelColor>
        <isBad>false</isBad>
        <stages>
            <li>
                <minSeverity>0</minSeverity>
                <label>Light and steady</label>
            </li>
        </stages>
    </HediffDef>
    <!-- Waiting for lactation drug to take effect; tooltip from HediffComp_AbsorptionDelayTip -->
    <HediffDef>
        <defName>EM_AbsorptionDelay</defName>
        <hediffClass>HediffWithComps</hediffClass>
        <label>Drug still taking hold</label>
        <description>The lactation dose is still working through the blood; the chest flushes with warmth before the milk truly comes in.</description>
        <defaultLabelColor>(0.7,0.85,1)</defaultLabelColor>
        <isBad>false</isBad>
        <comps>
            <li Class="MilkCum.Fluids.Lactation.Hediffs.HediffCompProperties_AbsorptionDelayTip" />
        </comps>
        <stages>
            <li>
                <minSeverity>0</minSeverity>
                <label>Absorbing dose</label>
            </li>
        </stages>
    </HediffDef>

    <!-- rjw-milkable-colonists compat; RJWLactatingGainPatch may add cap mods -->
    <HediffDef>
        <defName>Lactating_Drug</defName>
        <hediffClass>HediffWithComps</hediffClass>
        <label>Drug-induced lactation</label>
        <description>Lactation from medication; milk still fills the pools in the usual way for milking or nursing.</description>
        <defaultLabelColor>(1,0.41,0.81)</defaultLabelColor>
        <isBad>false</isBad>
        <stages>
            <li><minSeverity>0</minSeverity><label>Producing milk</label></li>
        </stages>
    </HediffDef>
    <HediffDef>
        <defName>Lactating_Permanent</defName>
        <hediffClass>HediffWithComps</hediffClass>
        <label>Permanent lactation</label>
        <description>The body simply keeps making milk unless something else suppresses it.</description>
        <defaultLabelColor>(1,0.41,0.81)</defaultLabelColor>
        <isBad>false</isBad>
        <stages>
            <li><minSeverity>0</minSeverity><label>Producing milk</label></li>
        </stages>
    </HediffDef>
    <HediffDef>
        <defName>Heavy_Lactating_Permanent</defName>
        <hediffClass>HediffWithComps</hediffClass>
        <label>Heavy permanent lactation</label>
        <description>Milk production is intense and relentless; the breasts rarely rest—more taxing than ordinary permanent lactation.</description>
        <defaultLabelColor>(1,0.41,0.81)</defaultLabelColor>
        <isBad>false</isBad>
        <stages>
            <li><minSeverity>0</minSeverity><label>Producing milk</label></li>
        </stages>
    </HediffDef>
</Defs>