<Defs>
    <ChemicalDef>
        <defName>EM_Prolactin_Chemical</defName>
        <label>Prolactin</label>
        <addictionHediff>EM_Prolactin_Addiction</addictionHediff>
        <toleranceHediff>EM_Prolactin_Tolerance</toleranceHediff>
        <onGeneratedAddictedToleranceChance>0.8</onGeneratedAddictedToleranceChance>
        <generateAddictionGenes>false</generateAddictionGenes>
    </ChemicalDef>

    <!-- 成瘾需求：fallPerDay 等供信息面板「成瘾需求降低速率」「成瘾需求间隔」显示；与 CompProperties_Drug.needLevelOffset 配合 -->
    <NeedDef ParentName="DrugAddictionNeedBase">
        <defName>Chemical_EM_Prolactin_Chemical</defName>
        <needClass>Need_Chemical</needClass>
        <label>Prolactin</label>
        <description>Because of a Prolactin addiction, this person needs to regularly consume the drug to avoid withdrawal symptoms.</description>
        <listPriority>45</listPriority>
        <fallPerDay>0.5</fallPerDay>
        <onlyIfCausedByHediff>true</onlyIfCausedByHediff>
        <tutorHighlightTag>NeedAddiction</tutorHighlightTag>
    </NeedDef>
</Defs>