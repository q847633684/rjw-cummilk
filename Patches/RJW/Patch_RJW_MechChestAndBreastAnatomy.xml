<?xml version="1.0" encoding="utf-8" ?>
<!-- 依赖 rim.job.world；仅当某身体图上存在 MechChest 叶时，替换为左右 MechBreast 并把 MechChest Def 改为 conceptual（无匹配则不改 Def，避免破坏仅有单叶 MechChest 的存档）。 -->
<Patch>
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>rim.job.world</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationFind">
					<xpath>Defs/BodyDef/corePart[def = "MechanicalThorax"]/parts/li[def="MechChest"]</xpath>
					<match Class="PatchOperationSequence">
						<operations>
							<li Class="PatchOperationReplace">
								<xpath>Defs/BodyDef/corePart[def = "MechanicalThorax"]/parts/li[def="MechChest"]</xpath>
								<value>
									<li>
										<def>MechChest</def>
										<coverage>0.001</coverage>
										<depth>Outside</depth>
										<parts>
											<li>
												<def>MechBreast</def>
												<customLabel>left mech breast</customLabel>
												<coverage>0.5</coverage>
												<depth>Outside</depth>
												<flipGraphic>true</flipGraphic>
											</li>
											<li>
												<def>MechBreast</def>
												<customLabel>right mech breast</customLabel>
												<coverage>0.5</coverage>
												<depth>Outside</depth>
											</li>
										</parts>
									</li>
								</value>
							</li>
							<li Class="PatchOperationReplace">
								<xpath>Defs/BodyPartDef[defName="MechChest"]</xpath>
								<value>
									<BodyPartDef>
										<defName>MechChest</defName>
										<label>chest</label>
										<conceptual>true</conceptual>
									</BodyPartDef>
								</value>
							</li>
						</operations>
					</match>
				</li>
				<li Class="PatchOperationFind">
					<xpath>Defs/BodyDef/corePart[def = "MechanicalThoraxCanManipulate"]/parts/li[def="MechChest"]</xpath>
					<match Class="PatchOperationSequence">
						<operations>
							<li Class="PatchOperationReplace">
								<xpath>Defs/BodyDef/corePart[def = "MechanicalThoraxCanManipulate"]/parts/li[def="MechChest"]</xpath>
								<value>
									<li>
										<def>MechChest</def>
										<coverage>0.001</coverage>
										<depth>Outside</depth>
										<parts>
											<li>
												<def>MechBreast</def>
												<customLabel>left mech breast</customLabel>
												<coverage>0.5</coverage>
												<depth>Outside</depth>
												<flipGraphic>true</flipGraphic>
											</li>
											<li>
												<def>MechBreast</def>
												<customLabel>right mech breast</customLabel>
												<coverage>0.5</coverage>
												<depth>Outside</depth>
											</li>
										</parts>
									</li>
								</value>
							</li>
							<li Class="PatchOperationReplace">
								<xpath>Defs/BodyPartDef[defName="MechChest"]</xpath>
								<value>
									<BodyPartDef>
										<defName>MechChest</defName>
										<label>chest</label>
										<conceptual>true</conceptual>
									</BodyPartDef>
								</value>
							</li>
						</operations>
					</match>
				</li>
			</operations>
		</match>
	</Operation>
</Patch>
